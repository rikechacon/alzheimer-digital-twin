# Alzheimer Digital Twin - Variables de Entorno de Ejemplo
# Copiar a .env y completar con valores reales

# Configuración API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Base de datos
DATABASE_URL=postgresql://user:password@localhost:5432/alzdt_db
REDIS_URL=redis://localhost:6379/0

# Seguridad
SECRET_KEY=change_this_in_production_very_secure_random_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Integración con servicios externos
FHIR_SERVER_URL=https://fhir-server.example.com
WEARABLE_API_KEY=your_wearable_api_key_here
CLOUD_STORAGE_BUCKET=alzdt-patient-data

# Configuración de simulación
SIMULATION_TIME_STEP=24.0
MONTE_CARLO_SAMPLES=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
